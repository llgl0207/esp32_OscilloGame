#define BAIDU_SECRET_KEY "your_baidu_secret_key"

// ==================== DeepSeek ====================
// 替换为你的 DeepSeek API Key (https://platform.deepseek.com/api_keys)
#define DEEPSEEK_API_KEY "your_deepseek_api_key"

// ==================== 独立串口对话模块 (src/merge/) ====================
// 以下为从 st7789IoT 工程迁移的语音+LLM 链路专用凭据
